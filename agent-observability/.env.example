# Agent-Insight 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# 后端服务地址
AGENT_INSIGHT_BACKEND=http://localhost:8000

# OpenAI API Key (用于 GPT-4 / GPT-4o / o1 等)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API Key (用于 Claude 系列)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek API Key (用于 DeepSeek-V3 / R1)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# vLLM / Ollama 等自建服务 (OpenAI 兼容接口)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# VLLM_BASE_URL=http://localhost:8000/v1
